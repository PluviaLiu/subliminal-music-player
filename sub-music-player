<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>多轨播放器</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  color-scheme:dark;
  --bg:#0f0f0f;--text:#e8e8e8;--panel:#1a1a1a;--transport:#111;
  --muted:#555;--muted-2:#666;--line:#222;--border:#333;--hover:#252525;
  --button:#aaa;--button-hover:#eee;--track:#ddd;--music-name:#ccc;--range:#2e2e2e;
  --delete:#444;--danger:#e06c6c;--sub:#7c6af7;--sub-soft:#2a2358;--sub-soft-text:#a99ffe;
  --music:#2eb87e;--music-soft:#1a2e22;--music-hover:#26a36e;
}
@media (prefers-color-scheme:light){
  :root{
    color-scheme:light;
    --bg:#f6f7fb;--text:#1f2328;--panel:#fff;--transport:#f0f2f6;
    --muted:#747986;--muted-2:#8b909b;--line:#e6e8ee;--border:#d7dbe3;--hover:#eef1f6;
    --button:#555c68;--button-hover:#1f2328;--track:#242830;--music-name:#3d444f;--range:#d9dde6;
    --delete:#a0a6b2;--danger:#d64545;--sub:#6f5df6;--sub-soft:#eeeaff;--sub-soft-text:#5d4ed8;
    --music:#229967;--music-soft:#e8f7ef;--music-hover:#1d865a;
  }
}
html[data-theme="dark"]{
  color-scheme:dark;
  --bg:#0f0f0f;--text:#e8e8e8;--panel:#1a1a1a;--transport:#111;
  --muted:#555;--muted-2:#666;--line:#222;--border:#333;--hover:#252525;
  --button:#aaa;--button-hover:#eee;--track:#ddd;--music-name:#ccc;--range:#2e2e2e;
  --delete:#444;--danger:#e06c6c;--sub:#7c6af7;--sub-soft:#2a2358;--sub-soft-text:#a99ffe;
  --music:#2eb87e;--music-soft:#1a2e22;--music-hover:#26a36e;
}
html[data-theme="light"]{
  color-scheme:light;
  --bg:#f6f7fb;--text:#1f2328;--panel:#fff;--transport:#f0f2f6;
  --muted:#747986;--muted-2:#8b909b;--line:#e6e8ee;--border:#d7dbe3;--hover:#eef1f6;
  --button:#555c68;--button-hover:#1f2328;--track:#242830;--music-name:#3d444f;--range:#d9dde6;
  --delete:#a0a6b2;--danger:#d64545;--sub:#6f5df6;--sub-soft:#eeeaff;--sub-soft-text:#5d4ed8;
  --music:#229967;--music-soft:#e8f7ef;--music-hover:#1d865a;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:24px;transition:background .18s,color .18s;}
.app{max-width:980px;margin:0 auto;}
.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;gap:12px;}
.top-actions{display:flex;align-items:center;justify-content:flex-end;gap:8px;flex-wrap:wrap;}
h1{font-size:13px;font-weight:500;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;}
.modules{display:flex;flex-direction:column;gap:16px;}
.app.split .modules{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);align-items:start;}

.module{background:var(--panel);border-radius:14px;padding:16px;min-width:0;transition:background .18s;}
.module-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:12px;}
.module-title{display:flex;align-items:center;gap:8px;font-size:14px;font-weight:600;min-width:0;}
.dot{width:8px;height:8px;border-radius:50%;}
.dot-sub{background:var(--sub);}
.dot-music{background:var(--music);}
.module-hint{font-size:11px;color:var(--muted);font-weight:400;margin-left:2px;}
.add-btn{font-size:12px;padding:5px 11px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--button);cursor:pointer;white-space:nowrap;}
.add-btn:hover{background:var(--hover);color:var(--button-hover);}
.module-actions{display:flex;align-items:center;justify-content:flex-end;gap:8px;flex-wrap:wrap;}
.empty{text-align:center;padding:22px;color:var(--muted);font-size:13px;border:1px dashed var(--line);border-radius:10px;}

#sub-list,.music-list{max-height:52vh;overflow:auto;padding-right:4px;}
.app.split #sub-list,.app.split .music-list{max-height:68vh;}

/* --- Subliminal tracks --- */
.sub-track{display:grid;grid-template-columns:34px 1fr auto;gap:0 10px;align-items:center;padding:10px 0;border-bottom:1px solid var(--line);}
.sub-track:last-child{border-bottom:none;}
.play-btn{width:34px;height:34px;border-radius:50%;border:1px solid var(--border);background:transparent;color:var(--button);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.play-btn:hover{background:var(--hover);color:var(--button-hover);}
.play-btn.active{background:var(--sub);border-color:var(--sub);color:#fff;}
.track-name{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--track);}
.track-sub{font-size:11px;color:var(--muted);margin-top:2px;}
input[type=range].prog{width:100%;height:2px;-webkit-appearance:none;background:var(--range);border-radius:2px;cursor:pointer;margin-top:7px;display:block;}
input[type=range].prog::-webkit-slider-thumb{-webkit-appearance:none;width:10px;height:10px;border-radius:50%;background:var(--sub);cursor:pointer;}
.sub-right{display:flex;flex-direction:column;align-items:flex-end;gap:7px;min-width:108px;}
.vol-row{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted);}
input[type=range].vol{width:64px;height:2px;-webkit-appearance:none;background:var(--range);border-radius:2px;cursor:pointer;}
input[type=range].vol::-webkit-slider-thumb{-webkit-appearance:none;width:10px;height:10px;border-radius:50%;background:var(--button);cursor:pointer;}
.loop-btn{font-size:11px;padding:3px 8px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--muted-2);cursor:pointer;}
.loop-btn.on{background:var(--sub-soft);border-color:var(--sub);color:var(--sub-soft-text);}
.del-btn{background:transparent;border:none;color:var(--delete);cursor:pointer;font-size:12px;}
.del-btn:hover{color:var(--danger);}
.limit-row{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted);}
.limit-input{width:46px;padding:2px 4px;border-radius:5px;border:1px solid var(--border);background:transparent;color:var(--button);font-size:11px;}
.limit-hit{font-size:11px;color:var(--danger);min-height:14px;}
.sub-track.disabled{opacity:.48;}
.sub-track.disabled .track-name,.sub-track.disabled .track-sub{color:var(--muted);}
.sub-track.disabled .play-btn,.sub-track.disabled .loop-btn{cursor:not-allowed;}
.sub-track.disabled input[type=range]{cursor:not-allowed;}

/* --- Music list --- */
.music-list{display:flex;flex-direction:column;gap:2px;margin-bottom:14px;}
.music-row{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;cursor:pointer;}
.music-row:hover{background:var(--hover);}
.music-row.active{background:var(--music-soft);}
.music-num{font-size:12px;color:var(--muted);width:18px;text-align:center;flex-shrink:0;}
.music-row.active .music-num{display:none;}
.play-ind{display:none;width:18px;text-align:center;flex-shrink:0;font-size:12px;color:var(--music);}
.music-row.active .play-ind{display:block;}
.music-name{flex:1;font-size:13px;color:var(--music-name);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.music-row.active .music-name{color:var(--music);font-weight:500;}
.music-dur{font-size:11px;color:var(--muted);flex-shrink:0;}
.music-del{background:transparent;border:none;color:var(--delete);cursor:pointer;font-size:12px;padding:2px 4px;opacity:0;}
.music-row:hover .music-del{opacity:1;}
.music-del:hover{color:var(--danger);}

/* --- Transport --- */
.transport{background:var(--transport);border-radius:10px;padding:12px 14px;transition:background .18s;}
.t-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.t-name{font-size:13px;color:var(--button);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
.t-time{font-size:11px;color:var(--muted);font-variant-numeric:tabular-nums;flex-shrink:0;margin-left:8px;}
input[type=range].tprog{width:100%;height:3px;-webkit-appearance:none;background:var(--range);border-radius:2px;cursor:pointer;display:block;margin-bottom:10px;}
input[type=range].tprog::-webkit-slider-thumb{-webkit-appearance:none;width:12px;height:12px;border-radius:50%;background:var(--music);cursor:pointer;}
.t-btns{display:flex;align-items:center;justify-content:center;gap:10px;}
.tbtn{width:36px;height:36px;border-radius:50%;border:1px solid var(--border);background:transparent;color:var(--button);cursor:pointer;font-size:14px;}
.tbtn:hover{background:var(--hover);color:var(--button-hover);}
.tbtn.main{width:42px;height:42px;font-size:16px;background:var(--music);border-color:var(--music);color:#fff;}
.tbtn.main:hover{background:var(--music-hover);}
.tbtn.loop-on{background:var(--music-soft);border-color:var(--music);color:var(--music);}
.loop-label{font-size:11px;color:var(--muted);margin-left:2px;}

@media (max-width:760px){
  body{padding:16px;}
  .topbar{align-items:flex-start;flex-direction:column;}
  .top-actions{justify-content:flex-start;}
  .app.split .modules{display:flex;flex-direction:column;}
  .module-header{align-items:flex-start;flex-direction:column;}
  .module-actions{justify-content:flex-start;}
  #sub-list,.music-list{max-height:none;}
}
</style>
</head>
<body>
<div class="app">
  <div class="topbar">
    <h1>多轨播放器</h1>
    <div class="top-actions">
      <button class="add-btn" id="theme-btn" onclick="cycleTheme()">跟随系统</button>
      <button class="add-btn" id="layout-btn" onclick="toggleLayout()">左右布局</button>
    </div>
  </div>

  <div class="modules">
  <!-- Module 1 -->
  <div class="module">
    <div class="module-header">
      <div class="module-title">
        <div class="dot dot-sub"></div>
        潜意识音频
        <span class="module-hint">多轨同时播放</span>
      </div>
      <div class="module-actions">
        <button class="add-btn" onclick="playAllSubs()">全部播放</button>
        <button class="add-btn" onclick="pauseAllSubs()">全部暂停</button>
        <button class="add-btn" onclick="document.getElementById('sub-input').click()">＋ 添加音轨</button>
      </div>
      <input type="file" id="sub-input" accept="audio/*" multiple style="display:none" onchange="addSubTracks(this.files);this.value=''">
    </div>
    <div id="sub-list"><div class="empty">添加潜意识音频 / 白噪音，各轨独立同时播放</div></div>
  </div>

  <!-- Module 2 -->
  <div class="module">
    <div class="module-header">
      <div class="module-title">
        <div class="dot dot-music"></div>
        音乐
        <span class="module-hint">切歌自动停上一首</span>
      </div>
      <div class="module-actions">
        <button class="add-btn" onclick="document.getElementById('mus-input').click()">＋ 添加音乐</button>
      </div>
      <input type="file" id="mus-input" accept="audio/*" multiple style="display:none" onchange="addMusic(this.files);this.value=''">
    </div>
    <div class="music-list" id="music-list"></div>
    <div id="empty-music" class="empty">添加你的音乐，点曲目切换，自动停止上一首</div>
    <div class="transport" id="transport" style="display:none">
      <div class="t-header">
        <span class="t-name" id="t-name">—</span>
        <span class="t-time" id="t-time">0:00 / 0:00</span>
      </div>
      <input type="range" class="tprog" id="t-prog" min="0" max="100" value="0" step="0.1" oninput="seekMusic(this.value)">
      <div class="t-btns">
        <button class="tbtn" onclick="prevMusic()" title="上一首">⏮</button>
        <button class="tbtn main" id="t-playbtn" onclick="toggleMusicPlay()">▶</button>
        <button class="tbtn" onclick="nextMusic()" title="下一首">⏭</button>
        <button class="tbtn" id="t-loop" onclick="cycleLoop()">🔁</button>
        <span class="loop-label" id="loop-label">单次</span>
      </div>
    </div>
  </div>
  </div>
</div>

<script>
// ========== UTILS ==========
function fmt(s){if(!isFinite(s))return'0:00';return Math.floor(s/60)+':'+String(Math.floor(s%60)).padStart(2,'0');}
let layoutMode=getSavedLayoutMode();
let themeMode=getSavedThemeMode();
const systemThemeQuery=window.matchMedia?window.matchMedia('(prefers-color-scheme: dark)'):null;
function getSavedLayoutMode(){try{return localStorage.getItem('layoutMode')||'stack';}catch(e){return'stack';}}
function saveLayoutMode(){try{localStorage.setItem('layoutMode',layoutMode);}catch(e){}}
function getSavedThemeMode(){try{return localStorage.getItem('themeMode')||'system';}catch(e){return'system';}}
function saveThemeMode(){try{localStorage.setItem('themeMode',themeMode);}catch(e){}}
function applyLayout(){
  const app=document.querySelector('.app'),btn=document.getElementById('layout-btn');
  if(!app)return;
  app.classList.toggle('split',layoutMode==='split');
  if(btn)btn.textContent=layoutMode==='split'?'上下布局':'左右布局';
}
function toggleLayout(){
  layoutMode=layoutMode==='split'?'stack':'split';
  saveLayoutMode();
  applyLayout();
}
function applyTheme(){
  const btn=document.getElementById('theme-btn'),labels={system:'跟随系统',light:'日间模式',dark:'夜间模式'};
  if(themeMode==='system')document.documentElement.removeAttribute('data-theme');
  else document.documentElement.setAttribute('data-theme',themeMode);
  if(btn)btn.textContent=labels[themeMode]||labels.system;
}
function cycleTheme(){
  const modes=['system','light','dark'];
  themeMode=modes[(modes.indexOf(themeMode)+1)%modes.length];
  saveThemeMode();
  applyTheme();
}
if(systemThemeQuery)systemThemeQuery.addEventListener('change',()=>{if(themeMode==='system')applyTheme();});

// ========== MODULE 1: SUBLIMINAL MIXER ==========
const subs=[];
const SUB_DAILY_STATE_KEY='subDailyPlayState';
function todayKey(){return new Date().toLocaleDateString('sv-SE');}
function getSubTrackKey(file){return [file.name,file.size,file.lastModified].join('|');}
function loadSubDailyState(){try{return JSON.parse(localStorage.getItem(SUB_DAILY_STATE_KEY)||'{}')||{};}catch(e){return{};}}
function saveSubDailyState(state){try{localStorage.setItem(SUB_DAILY_STATE_KEY,JSON.stringify(state));}catch(e){}}
function getSubDailyRecord(key){
  const state=loadSubDailyState(),today=todayKey();
  const saved=state[key]||{};
  const record={date:today,count:saved.date===today?Number(saved.count)||0:0,limit:Math.max(0,parseInt(saved.limit,10)||0)};
  state[key]=record;saveSubDailyState(state);
  return record;
}
function saveSubDailyRecord(t){const state=loadSubDailyState();state[t.key]={date:t.daily.date,count:t.daily.count,limit:t.daily.limit};saveSubDailyState(state);}
function refreshSubDailyDate(t){
  const today=todayKey();
  if(t.daily.date!==today){t.daily.date=today;t.daily.count=0;saveSubDailyRecord(t);}
}
function hasSubDailyLimit(t){return t.daily.limit>0;}
function isSubLimitReached(t){refreshSubDailyDate(t);return hasSubDailyLimit(t)&&t.daily.count>=t.daily.limit;}
function syncSubAudioLoop(t){t.audio.loop=false;}
function addSubTracks(files){
  const list=document.getElementById('sub-list');
  if(list.querySelector('.empty'))list.innerHTML='';
  Array.from(files).forEach(f=>{
    const id='s'+Date.now()+Math.random().toString(36).slice(2,6);
    const audio=new Audio(URL.createObjectURL(f));
    audio.volume=0.8;
    const key=getSubTrackKey(f),daily=getSubDailyRecord(key);
    const t={id,audio,file:f,loop:true,key,daily};
    syncSubAudioLoop(t);
    subs.push(t);
    const d=document.createElement('div');
    d.className='sub-track'; d.id=id;
    d.innerHTML=`
      <button class="play-btn" id="pb${id}" onclick="toggleSub('${id}')">▶</button>
      <div>
        <div class="track-name" title="${f.name}">${f.name.replace(/\.[^/.]+$/,'')}</div>
        <div class="track-sub"><span id="sc${id}">0:00</span> / <span id="sd${id}">--:--</span> · 今日 <span id="scc${id}">0</span> / <span id="scl${id}">不限</span></div>
        <input type="range" class="prog" id="sp${id}" min="0" max="100" value="0" step="0.1" oninput="seekSub('${id}',this.value)">
      </div>
      <div class="sub-right">
        <div style="display:flex;gap:6px;align-items:center">
          <button class="loop-btn on" id="lb${id}" onclick="toggleSubLoop('${id}')">循环</button>
          <button class="del-btn" onclick="removeSub('${id}')">✕</button>
        </div>
        <div class="limit-row">上限
          <input class="limit-input" id="slim${id}" type="number" min="0" step="1" value="${daily.limit||''}" placeholder="不限" onchange="setSubDailyLimit('${id}',this.value)">
        </div>
        <div class="limit-hit" id="shit${id}"></div>
        <div class="vol-row">🔈
          <input type="range" class="vol" id="svol${id}" min="0" max="1" step="0.01" value="0.8" oninput="setSubVol('${id}',this.value)">
          <span id="sv${id}">80%</span>
        </div>
      </div>`;
    list.appendChild(d);
    audio.addEventListener('loadedmetadata',()=>{const e=document.getElementById('sd'+id);if(e)e.textContent=fmt(audio.duration);});
    audio.addEventListener('timeupdate',()=>{
      if(!audio.duration)return;
      const p=document.getElementById('sp'+id),c=document.getElementById('sc'+id);
      if(p&&document.activeElement!==p)p.value=(audio.currentTime/audio.duration)*100;
      if(c)c.textContent=fmt(audio.currentTime);
    });
    audio.addEventListener('ended',()=>onSubEnded(id));
    updateSubLimitUI(id);
  });
}
function updateSubPlayButton(id,playing){
  const t=subs.find(x=>x.id===id),pb=document.getElementById('pb'+id);if(!pb)return;
  if(t&&isSubLimitReached(t)){pb.className='play-btn';pb.textContent='▶';pb.disabled=true;return;}
  pb.disabled=false;pb.className='play-btn'+(playing?' active':'');pb.textContent=playing?'⏸':'▶';
}
function updateSubLimitUI(id){
  const t=subs.find(x=>x.id===id);if(!t)return;
  refreshSubDailyDate(t);
  const reached=isSubLimitReached(t),el=document.getElementById(id),count=document.getElementById('scc'+id),limit=document.getElementById('scl'+id),hit=document.getElementById('shit'+id),prog=document.getElementById('sp'+id),vol=document.getElementById('svol'+id),loop=document.getElementById('lb'+id),input=document.getElementById('slim'+id);
  if(count)count.textContent=t.daily.count;
  if(limit)limit.textContent=hasSubDailyLimit(t)?t.daily.limit:'不限';
  if(hit)hit.textContent=reached?'已达上限':'';
  if(el)el.classList.toggle('disabled',reached);
  if(prog)prog.disabled=reached;
  if(vol)vol.disabled=reached;
  if(loop)loop.disabled=reached;
  if(input&&document.activeElement!==input)input.value=t.daily.limit||'';
  updateSubPlayButton(id,!t.audio.paused&& !reached);
}
function recordSubCompletedPlay(t){refreshSubDailyDate(t);t.daily.count++;saveSubDailyRecord(t);updateSubLimitUI(t.id);}
function stopSubForLimit(t){t.audio.pause();t.audio.currentTime=0;updateSubPlayButton(t.id,false);updateSubLimitUI(t.id);}
function onSubEnded(id){
  const t=subs.find(x=>x.id===id);if(!t)return;
  recordSubCompletedPlay(t);
  if(isSubLimitReached(t)){stopSubForLimit(t);return;}
  if(t.loop){t.audio.currentTime=0;t.audio.play().then(()=>updateSubPlayButton(id,true)).catch(()=>updateSubPlayButton(id,false));}
  else updateSubPlayButton(id,false);
}
function setSubDailyLimit(id,value){
  const t=subs.find(x=>x.id===id);if(!t)return;
  const n=Math.max(0,parseInt(value,10)||0);
  refreshSubDailyDate(t);t.daily.limit=n;saveSubDailyRecord(t);syncSubAudioLoop(t);
  if(isSubLimitReached(t))stopSubForLimit(t);else updateSubLimitUI(id);
}
function toggleSub(id){
  const t=subs.find(x=>x.id===id);if(!t)return;
  if(isSubLimitReached(t)){stopSubForLimit(t);return;}
  syncSubAudioLoop(t);
  if(t.audio.paused){t.audio.play().then(()=>updateSubPlayButton(id,true)).catch(()=>{});}
  else{t.audio.pause();updateSubPlayButton(id,false);}
}
function playAllSubs(){
  if(!subs.length)return;
  const plays=subs.filter(t=>!isSubLimitReached(t)).map(t=>{
    syncSubAudioLoop(t);t.audio.currentTime=0;
    return t.audio.play().then(()=>updateSubPlayButton(t.id,true)).catch(()=>{});
  });
  subs.filter(t=>isSubLimitReached(t)).forEach(t=>stopSubForLimit(t));
  Promise.allSettled(plays);
}
function pauseAllSubs(){
  subs.forEach(t=>{t.audio.pause();updateSubPlayButton(t.id,false);});
}
function toggleSubLoop(id){
  const t=subs.find(x=>x.id===id);if(!t)return;
  if(isSubLimitReached(t)){updateSubLimitUI(id);return;}
  t.loop=!t.loop;syncSubAudioLoop(t);
  const lb=document.getElementById('lb'+id);
  lb.className='loop-btn'+(t.loop?' on':'');lb.textContent=t.loop?'循环':'单次';
}
function setSubVol(id,v){
  const t=subs.find(x=>x.id===id);if(!t||isSubLimitReached(t))return;
  t.audio.volume=parseFloat(v);
  const e=document.getElementById('sv'+id);if(e)e.textContent=Math.round(v*100)+'%';
}
function seekSub(id,v){
  const t=subs.find(x=>x.id===id);if(!t||!t.audio.duration||isSubLimitReached(t))return;
  t.audio.currentTime=(v/100)*t.audio.duration;
}
function removeSub(id){
  const i=subs.findIndex(x=>x.id===id);if(i<0)return;
  subs[i].audio.pause();URL.revokeObjectURL(subs[i].audio.src);subs.splice(i,1);
  const el=document.getElementById(id);if(el)el.remove();
  if(subs.length===0)document.getElementById('sub-list').innerHTML='<div class="empty">添加潜意识音频 / 白噪音，各轨独立同时播放</div>';
}

// ========== MODULE 2: MUSIC PLAYER ==========
const musics=[];
let curIdx=-1;
let loopMode='none'; // none | one | all
const mAudio=new Audio();
mAudio.addEventListener('timeupdate',updateMusicUI);
mAudio.addEventListener('loadedmetadata',updateMusicUI);
mAudio.addEventListener('ended',onEnded);

function addMusic(files){
  Array.from(files).forEach(f=>{
    const id='m'+Date.now()+Math.random().toString(36).slice(2,6);
    const probe=new Audio(); 
    const blobUrl=URL.createObjectURL(f);
    probe.src=blobUrl;
    const t={id,file:f,dur:'--:--',url:blobUrl};
    musics.push(t);
    probe.addEventListener('loadedmetadata',()=>{
      t.dur=fmt(probe.duration);
      const e=document.getElementById('md'+id);if(e)e.textContent=t.dur;
    });
    renderMusic();
  });
  document.getElementById('empty-music').style.display='none';
  document.getElementById('transport').style.display='block';
  if(curIdx<0)loadMusic(0);
}

function renderMusic(){
  const list=document.getElementById('music-list');
  list.innerHTML='';
  musics.forEach((t,i)=>{
    const active=i===curIdx;
    const row=document.createElement('div');
    row.className='music-row'+(active?' active':'');
    row.innerHTML=`
      <span class="music-num">${i+1}</span>
      <span class="play-ind">▶</span>
      <span class="music-name" title="${t.file.name}">${t.file.name.replace(/\.[^/.]+$/,'')}</span>
      <span class="music-dur" id="md${t.id}">${t.dur}</span>
      <button class="music-del" onclick="removeMusic(${i},event)">✕</button>`;
    row.addEventListener('click',e=>{
      if(e.target.classList.contains('music-del'))return;
      if(i===curIdx){toggleMusicPlay();}
      else{loadMusic(i);mAudio.play();setPlayBtn(false);}
    });
    list.appendChild(row);
  });
}

function loadMusic(idx){
  if(idx<0||idx>=musics.length)return;
  const was=!mAudio.paused;
  mAudio.pause();
  curIdx=idx;
  mAudio.src=musics[idx].url;
  mAudio.load();
  mAudio.loop=(loopMode==='one');
  document.getElementById('t-name').textContent=musics[idx].file.name.replace(/\.[^/.]+$/,'');
  document.getElementById('t-prog').value=0;
  document.getElementById('t-time').textContent='0:00 / 0:00';
  renderMusic();
  if(was){mAudio.play();setPlayBtn(false);}else{setPlayBtn(true);}
}
function toggleMusicPlay(){
  if(mAudio.src==='')return;
  if(mAudio.paused){mAudio.play();setPlayBtn(false);}
  else{mAudio.pause();setPlayBtn(true);}
}
function setPlayBtn(paused){document.getElementById('t-playbtn').textContent=paused?'▶':'⏸';}
function prevMusic(){if(!musics.length)return;loadMusic((curIdx-1+musics.length)%musics.length);mAudio.play();setPlayBtn(false);}
function nextMusic(){if(!musics.length)return;loadMusic((curIdx+1)%musics.length);mAudio.play();setPlayBtn(false);}
function seekMusic(v){if(!mAudio.duration)return;mAudio.currentTime=(v/100)*mAudio.duration;}
function updateMusicUI(){
  if(!mAudio.duration)return;
  const p=document.getElementById('t-prog');
  if(p&&document.activeElement!==p)p.value=(mAudio.currentTime/mAudio.duration)*100;
  document.getElementById('t-time').textContent=fmt(mAudio.currentTime)+' / '+fmt(mAudio.duration);
}
function onEnded(){
  if(loopMode==='one')return;
  if(loopMode==='all'){nextMusic();return;}
  setPlayBtn(true);
}
function cycleLoop(){
  const modes=['none','one','all'];
  const icons=['🔁','🔂','🔁'];
  const labels=['单次','单曲循环','列表循环'];
  loopMode=modes[(modes.indexOf(loopMode)+1)%3];
  const i=modes.indexOf(loopMode);
  mAudio.loop=(loopMode==='one');
  const btn=document.getElementById('t-loop');
  btn.textContent=icons[i];
  btn.className='tbtn'+(loopMode!=='none'?' loop-on':'');
  document.getElementById('loop-label').textContent=labels[i];
}
function removeMusic(idx,e){
  e.stopPropagation();
  URL.revokeObjectURL(musics[idx].url);
  musics.splice(idx,1);
  if(idx===curIdx){
    mAudio.pause();mAudio.src='';
    curIdx=musics.length>0?Math.min(idx,musics.length-1):-1;
    if(curIdx>=0)loadMusic(curIdx);
    else{document.getElementById('t-name').textContent='—';document.getElementById('t-prog').value=0;document.getElementById('t-time').textContent='0:00 / 0:00';}
  }else if(idx<curIdx){curIdx--;}
  renderMusic();
  if(musics.length===0){document.getElementById('empty-music').style.display='';document.getElementById('transport').style.display='none';}
}
applyTheme();
applyLayout();
</script>
